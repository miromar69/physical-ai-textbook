# Database — Neon Serverless Postgres connection string
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Qdrant Cloud
QDRANT_URL=https://xxx.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key

# Auth — secret for JWT session token signing (generate a random 64-char hex string)
BETTER_AUTH_SECRET=your-random-secret-here

# Auth — backend URL (used for session cookie domain)
BETTER_AUTH_URL=https://api.yourdomain.com

# CORS — frontend URL (GitHub Pages URL)
FRONTEND_URL=https://your-username.github.io
